generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  RADIOLOGIST
  RESEARCHER
  ADMIN
  SUPER_ADMIN
}

enum ImageModality {
  BRAIN_MRI
  SPINE_MRI
  CHEST_XRAY
  CT_SCAN
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(PATIENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  patient     Patient?
  doctor      Doctor?
  radiologist Radiologist?

  uploadedImages MedicalImage[]
}

model Patient {
  id           String   @id @default(uuid())
  userId       String   @unique
  age          Int?
  gender       String?
  bloodGroup   String?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  medicalImages MedicalImage[]
}

model Doctor {
  id             String @id @default(uuid())
  userId         String @unique
  specialization String?
  experience     Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Radiologist {
  id        String @id @default(uuid())
  userId    String @unique
  expertise String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedicalImage {
  id           String        @id @default(uuid())
  patientId    String
  uploadedById String

  imageUrl     String
  modality     ImageModality

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  patient    Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  uploadedBy User    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  aiPrediction AIPrediction?

  @@index([modality])
  @@index([createdAt])
}

model AIPrediction {
  id         String  @id @default(uuid())
  imageId    String  @unique

  modelName  String
  prediction String
  confidence Float
  severity   Severity?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  medicalImage MedicalImage @relation(fields: [imageId], references: [id], onDelete: Cascade)
}
